# URL pública del sitio (sin barra final)
NEXT_PUBLIC_SITE_URL=https://semillaclimatica.com

# Mercado Pago — Credenciales de producción
# Obtener en: https://www.mercadopago.com.mx/developers/panel/app
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx

# Usar "true" solo para pruebas con tarjetas de test
MP_SANDBOX=false

# Secreto para /api/revalidate (opcional)
REVALIDATE_SECRET=

# Meta Pixel — ID numérico desde business.facebook.com/events_manager
# Ejemplo: NEXT_PUBLIC_META_PIXEL_ID=123456789012345
NEXT_PUBLIC_META_PIXEL_ID=
